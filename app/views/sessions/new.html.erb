<% content_for :title, "Sign in" %>

<div class="auth-card">
  <h1>Sign in</h1>

  <%= form_with url: session_path, data: { turbo: false } do |form| %>
    <%= form.label :email_address, "Email" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address] %>

    <%= form.label :password, "Password" %>
    <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72 %>

    <div class="actions">
      <%= form.submit "Sign in" %>
    </div>
  <% end %>

  <p class="entry-meta" style="margin-top: 1rem; text-align: center;">
    No account? <%= link_to "Create one", new_registration_path %>
  </p>
</div>
